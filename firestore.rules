/**
 * @fileoverview Firestore Security Rules for the iykyk application.
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for personal data (under /users/{userId})
 * while allowing public read access to certain collections like /venues, /deals, /communities, /socials and /stays.
 * Write access is carefully controlled based on ownership, roles, or membership.  The primary goal
 * is to balance ease of querying with strong authorization.
 *
 * Data Structure:
 * - /users/{userId}: User profiles and associated private data.
 * - /venues/{venueId}: Venue information.
 * - /venues/{venueId}/experiences/{experienceId}: Experiences at a venue.
 * - /deals/{dealId}: Deals and promotions.
 * - /communities/{communityId}: Communities within the platform.
 * - /socials/{socialId}: Social activities.
 * - /stays/{stayId}: Creator-recommended stays.
 *
 * Key Security Decisions:
 * - Users can only modify their own profiles.
 * - Public read access is granted to venues, deals, communities, socials and stays.
 * - Subcollections under /users are strictly private to the user.
 * - Listing of users is disallowed.
 *
 * Denormalization for Authorization:
 * - The `deals` collection denormalizes `venueName` and `creatorId` to avoid `get()` calls for authorization.
 * - The `socials` collection denormalizes `hostUsername`.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profiles.  Any signed-in user can read a profile, but only the owner can modify it.
     * @path /users/{userId}
     * @allow (get): A signed-in user can read any user profile.
     * @allow (create, update, delete): Only the user with the matching userId can modify their own profile.
     * @deny (list): Listing all users is not permitted.
     * @principle Enforces user-ownership for writes, allows public reads for signed-in users.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to deals claimed by a user.
     * @path /users/{userId}/claimedDeals/{dealId}
     * @allow (create, get, update, delete, list): Only the user with the matching userId can access their claimed deals.
     * @deny:  Other users cannot access this data.
     * @principle Enforces user-ownership for all operations.
     */
    match /users/{userId}/claimedDeals/{dealId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to social activities joined by a user.
     * @path /users/{userId}/joinedSocials/{socialId}
     * @allow (create, get, update, delete, list): Only the user with the matching userId can access their joined socials.
     * @deny: Other users cannot access this data.
     * @principle Enforces user-ownership for all operations.
     */
    match /users/{userId}/joinedSocials/{socialId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to creators followed by a user.
     * @path /users/{userId}/following/{creatorId}
     * @allow (create, get, update, delete, list): Only the user with the matching userId can access their followed creators.
     * @deny: Other users cannot access this data.
     * @principle Enforces user-ownership for all operations.
     */
    match /users/{userId}/following/{creatorId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to stays saved by a user.
     * @path /users/{userId}/savedStays/{stayId}
     * @allow (create, get, update, delete, list): Only the user with the matching userId can access their saved stays.
     * @deny: Other users cannot access this data.
     * @principle Enforces user-ownership for all operations.
     */
    match /users/{userId}/savedStays/{stayId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to venue information.
     * @path /venues/{venueId}
     * @allow (get, list): Any user can read venue information.
     * @deny (create, update, delete): Only authorized admin can manage venue
     * @principle Allows public reads, restricts writes.
     */
    match /venues/{venueId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add admin role check for venue management
    }

    /**
     * @description Controls access to experiences associated with a venue.
     * @path /venues/{venueId}/experiences/{experienceId}
     * @allow (get, list): Any user can read experience information.
     * @deny (create, update, delete): Only authorized admin can manage experiences.
     * @principle Allows public reads, restricts writes.
     */
    match /venues/{venueId}/experiences/{experienceId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add admin role check for experience management
    }

    /**
     * @description Controls access to deals.
     * @path /deals/{dealId}
     * @allow (get, list): Any user can read deal information.
     * @deny (create, update, delete): Only authorized creators can manage deals. The `creatorId` must match the authenticated user.
     * @principle Allows public reads, restricts writes to the creator.
     */
    match /deals/{dealId} {
      allow get, list: if true;
      allow create: if request.auth != null; // TODO: Add creator role and deal validation
      allow update: if false; // TODO: Implement update rule
      allow delete: if false; // TODO: Implement delete rule
    }

    /**
     * @description Controls access to communities.
     * @path /communities/{communityId}
     * @allow (get, list): Any user can read community information.
     * @deny (create, update, delete): Only authorized admin can manage community.
     * @principle Allows public reads, restricts writes to administrators.
     */
    match /communities/{communityId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add admin role check for community management
    }

    /**
     * @description Controls access to social activities.
     * @path /socials/{socialId}
     * @allow (get, list): Any user can read social activity information.
     * @allow (create): A signed-in user can create a social activity.
     * @allow (update, delete): Only the host of the activity can update or delete it.
     * @principle Allows public reads, restricts writes to the host.
     */
    match /socials/{socialId} {
      allow get, list: if true;
      allow create: if request.auth != null; // TODO: Add social activity validation
      allow update: if false; // TODO: Implement update rule
      allow delete: if false; // TODO: Implement delete rule
    }

    /**
     * @description Controls access to participants in a social activity.
     * @path /socials/{socialId}/participants/{userId}
     * @allow (get, list): Any user can read participant information within a social activity.
     * @allow (create): A user can request or join a social activity.
     * @allow (update, delete): Only the host or the participant can update or delete participation status.
     */
    match /socials/{socialId}/participants/{userId} {
      allow get, list: if true; // Any user can see the list of participants
      allow create: if request.auth.uid == userId; // A user can request/join
      allow update: if false; // TODO: Implement update rule
      allow delete: if request.auth.uid == userId; // A user can leave
    }

    /**
     * @description Controls access to stays.
     * @path /stays/{stayId}
     * @allow (get, list): Any user can read stay information.
     * @deny (create, update, delete): Only authorized creators can manage stays.
     * @principle Allows public reads, restricts writes to the creator.
     */
    match /stays/{stayId} {
      allow get, list: if true;
      allow create: if request.auth != null; // TODO: Add creator role and stay validation
      allow update: if false; // TODO: Implement update rule
      allow delete: if false; // TODO: Implement delete rule
    }

    // ---- Helper functions ----

    /**
     * @description Checks if the user is signed in.
     * @return {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the request is made by the owner of the resource.
     * @param {string} userId The user ID to compare against the request's auth UID.
     * @return {boolean} True if the request is made by the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the request is made by the existing owner of the resource and the resource exists.
     * @param {string} userId The user ID to compare against the request's auth UID.
     * @return {boolean} True if the request is made by the existing owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}