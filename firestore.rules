/**
 * @file Firebase Security Rules for iykyk Firestore database.
 *
 * Core Philosophy:
 * This ruleset prioritizes security and data ownership, enforcing strict access controls based on user authentication and path-based authorization. Public read access is granted only where explicitly intended. Data validation is relaxed to allow for rapid prototyping, focusing on authorization-critical fields.
 *
 * Data Structure:
 * - /users/{userId}: User profiles and personal data, accessible only to the owning user.
 *      - /users/{userId}/claimedDeals/{dealId}: Deals claimed by a user, accessible only by the user.
 *      - /users/{userId}/joinedSocials/{socialId}: Social activities joined by a user, accessible only by the user.
 *      - /users/{userId}/following/{creatorId}: Users (creators) followed by a user, accessible only by the user.
 *      - /users/{userId}/savedStays/{stayId}: Stays saved by a user, accessible only by the user.
 * - /venues/{venueId}: Public venue information.
 *      - /venues/{venueId}/experiences/{experienceId}: Experiences at a venue, publicly accessible.
 * - /deals/{dealId}: Public deals and fire items.
 * - /communities/{communityId}: Public community information.
 * - /socials/{socialId}: Public social activities.
 *      - /socials/{socialId}/participants/{userId}: Participants in a social activity, where access is controlled by the host.
 * - /stays/{stayId}: Public stay information.
 *
 * Key Security Decisions:
 * - User data is strictly private, accessible only to the owning user.
 * - Public collections (venues, deals, communities, socials, stays) are readable by all.
 * - List operations are generally allowed for user-owned subcollections, but are disabled for other collections to prevent unintended data exposure.
 * - Data validation is minimal, focusing on authorization-critical fields to enable rapid iteration.
 *
 * Denormalization for Authorization:
 * None needed as there are no get() calls in security rules, promoting atomic operations and simplifying debugging.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profiles and their personal data. Only the user can access their own data.
     * @path /users/{userId}
     * @allow (create) - User with ID 'user123' creates their profile: request.auth.uid == 'user123'
     * @allow (get, update, delete) - User with ID 'user123' reads/updates/deletes their profile: request.auth.uid == 'user123'
     * @deny (create) - User with ID 'user123' tries to create a profile for 'user456': request.auth.uid == 'user123'
     * @principle Enforces user-ownership for data privacy.
     */
    match /users/{userId} {
      // Helper function to check if the requesting user is the owner of the document.
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      // Helper function to check if the requesting user is the existing owner of the document.
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);

      /**
       * @description Tracks deals claimed by a user. Only the user can manage their claimed deals.
       * @path /users/{userId}/claimedDeals/{dealId}
       * @allow (create) - User with ID 'user123' claims a deal: request.auth.uid == 'user123'
       * @allow (get, update, delete) - User with ID 'user123' reads/updates/deletes their claimed deal record: request.auth.uid == 'user123'
       * @deny (create) - User with ID 'user123' tries to claim a deal for 'user456': request.auth.uid == 'user123'
       * @principle Enforces user-ownership for data privacy.
       */
      match /claimedDeals/{dealId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Tracks social activities a user has joined. Only the user can manage their joined socials.
       * @path /users/{userId}/joinedSocials/{socialId}
       * @allow (create) - User with ID 'user123' joins a social: request.auth.uid == 'user123'
       * @allow (get, update, delete) - User with ID 'user123' reads/updates/deletes their joined social record: request.auth.uid == 'user123'
       * @deny (create) - User with ID 'user123' tries to join a social for 'user456': request.auth.uid == 'user123'
       * @principle Enforces user-ownership for data privacy.
       */
      match /joinedSocials/{socialId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Tracks users (creators) a user is following. Only the user can manage their following list.
       * @path /users/{userId}/following/{creatorId}
       * @allow (create) - User with ID 'user123' follows a creator: request.auth.uid == 'user123'
       * @allow (get, update, delete) - User with ID 'user123' reads/updates/deletes their following record: request.auth.uid == 'user123'
       * @deny (create) - User with ID 'user123' tries to follow a creator for 'user456': request.auth.uid == 'user123'
       * @principle Enforces user-ownership for data privacy.
       */
      match /following/{creatorId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Tracks stays a user has saved. Only the user can manage their saved stays.
       * @path /users/{userId}/savedStays/{stayId}
       * @allow (create) - User with ID 'user123' saves a stay: request.auth.uid == 'user123'
       * @allow (get, update, delete) - User with ID 'user123' reads/updates/deletes their saved stay record: request.auth.uid == 'user123'
       * @deny (create) - User with ID 'user123' tries to save a stay for 'user456': request.auth.uid == 'user123'
       * @principle Enforces user-ownership for data privacy.
       */
      match /savedStays/{stayId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Stores venue information. Venues are publicly readable.
     * @path /venues/{venueId}
     * @allow (get, list) - Any user can read venue information.
     * @deny (create, update, delete) - No user can create, update or delete venue information.
     * @principle Public read, owner-only writes.
     */
    match /venues/{venueId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      /**
       * @description Stores experiences associated with a venue. Experiences are publicly readable.
       * @path /venues/{venueId}/experiences/{experienceId}
       * @allow (get, list) - Any user can read experience information.
       * @deny (create, update, delete) - No user can create, update or delete experience information.
       * @principle Public read, owner-only writes.
       */
      match /experiences/{experienceId} {
        allow get: if true;
        allow list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    /**
     * @description Stores deals and fire items. Deals are publicly readable.
     * @path /deals/{dealId}
     * @allow (get, list) - Any user can read deal information.
     * @deny (create, update, delete) - No user can create, update or delete deal information.
     * @principle Public read, owner-only writes.
     */
    match /deals/{dealId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Stores community information. Communities are publicly readable.
     * @path /communities/{communityId}
     * @allow (get, list) - Any user can read community information.
     * @deny (create, update, delete) - No user can create, update or delete community information.
     * @principle Public read, owner-only writes.
     */
    match /communities/{communityId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Stores social activities. Socials are publicly readable.
     * @path /socials/{socialId}
     * @allow (get, list) - Any user can read social activity information.
     * @deny (create, update, delete) - No user can create, update or delete social activity information.
     * @principle Public read, owner-only writes.
     */
    match /socials/{socialId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;

      /**
       * @description Manages participants for a specific social activity.
       * @path /socials/{socialId}/participants/{userId}
       * @allow (get) - Any user can get participant information for this social
       * @allow (list) - Any user can list participant information for this social
       * @deny (create, update, delete) - No user can create, update or delete participant information.
       * @principle Public read, owner-only writes.
       */
      match /participants/{userId} {
        allow get: if true;
        allow list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
      }
    }

    /**
     * @description Stores stay information. Stays are publicly readable.
     * @path /stays/{stayId}
     * @allow (get, list) - Any user can read stay information.
     * @deny (create, update, delete) - No user can create, update or delete stay information.
     * @principle Public read, owner-only writes.
     */
    match /stays/{stayId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}