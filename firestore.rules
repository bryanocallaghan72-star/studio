/**
 * @file Firestore Security Rules
 * @description This ruleset enforces a strict user-ownership model for user profiles and
 * manages access to other collections based on roles, shared access, or public readability
 * with owner-only writes.
 *
 * Data Structure:
 * - /users/{userId}: User profiles, accessible only to the owner for writes, but readable by all signed-in users.
 * - /venues/{venueId}: Public venue information.
 * - /venues/{venueId}/experiences/{experienceId}: Experiences associated with a venue, publicly readable.
 * - /deals/{dealId}: Public deals and promotions.
 * - /communities/{communityId}: Community information with role-based access control via a 'members' map.
 * - /socials/{socialId}: Public collection for user-created social activities
 * - /socials/{socialId}/participants/{userId}: Manages participants for social activities.
 * - /stays/{stayId}: Public collection for creator-recommended stays.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect privacy.
 * - Public collections (venues, deals, socials, stays) are readable by anyone, but writes are restricted based on ownership.
 * - Communities use a 'members' map for role-based access.
 *
 * Denormalization for Authorization:
 * - The `venueName` and `creatorId` are denormalized into the `/deals` collection to avoid `get()` calls
 * when querying deals.
 * - Host information is denormalized from `/users` to `/socials` for authorization.
 *
 * Structural Segregation:
 * - User-specific data is stored under `/users/{userId}` to enforce ownership.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile data.
     * @path /users/{userId}
     * @allow (get) Signed-in user can read any profile.
     * @allow (create) User can create their own profile.
     * @allow (update) User can update their own profile.
     * @allow (delete) User can delete their own profile.
     * @deny (list) Listing all users is not allowed.
     * @principle Enforces document ownership for writes; allows public read for signed-in users.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to deals claimed by a user.
     * @path /users/{userId}/claimedDeals/{dealId}
     * @allow (create) User can create a claimed deal record under their profile.
     * @allow (get) User can read their own claimed deal records.
     * @allow (update) User can update their own claimed deal records.
     * @allow (delete) User can delete their own claimed deal records.
     * @allow (list) User can list their own claimed deal records.
     * @deny (create) User cannot create a claimed deal for another user.
     * @deny (update) User cannot update a claimed deal for another user.
     * @deny (delete) User cannot delete a claimed deal for another user.
     * @principle Enforces document ownership for claimed deals.
     */
    match /users/{userId}/claimedDeals/{dealId} {
      allow create: if isOwner(userId);
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to social activities joined by a user.
     * @path /users/{userId}/joinedSocials/{socialId}
     * @allow (create) User can create a joined social record under their profile.
     * @allow (get) User can read their own joined social records.
     * @allow (update) User can update their own joined social records.
     * @allow (delete) User can delete their own joined social records.
     * @allow (list) User can list their own joined social records.
     * @deny (create) User cannot create a joined social for another user.
     * @deny (update) User cannot update a joined social for another user.
     * @deny (delete) User cannot delete a joined social for another user.
     * @principle Enforces document ownership for joined socials.
     */
    match /users/{userId}/joinedSocials/{socialId} {
      allow create: if isOwner(userId);
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to creators followed by a user.
     * @path /users/{userId}/following/{creatorId}
     * @allow (create) User can create a following record under their profile.
     * @allow (get) User can read their own following records.
     * @allow (update) User can update their own following records.
     * @allow (delete) User can delete their own following records.
     * @allow (list) User can list their own following records.
     * @deny (create) User cannot create a following for another user.
     * @deny (update) User cannot update a following for another user.
     * @deny (delete) User cannot delete a following for another user.
     * @principle Enforces document ownership for following records.
     */
    match /users/{userId}/following/{creatorId} {
      allow create: if isOwner(userId);
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to stays saved by a user.
     * @path /users/{userId}/savedStays/{stayId}
     * @allow (create) User can create a saved stay record under their profile.
     * @allow (get) User can read their own saved stay records.
     * @allow (update) User can update their own saved stay records.
     * @allow (delete) User can delete their own saved stay records.
     * @allow (list) User can list their own saved stay records.
     * @deny (create) User cannot create a saved stay for another user.
     * @deny (update) User cannot update a saved stay for another user.
     * @deny (delete) User cannot delete a saved stay for another user.
     * @principle Enforces document ownership for saved stays.
     */
    match /users/{userId}/savedStays/{stayId} {
      allow create: if isOwner(userId);
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to venue information.
     * @path /venues/{venueId}
     * @allow (get) Anyone can read venue information.
     * @allow (list) Anyone can list venues.
     * @deny (create) Creating venues is not allowed. // TODO: Add role-based access for venue creation.
     * @deny (update) Updating venues is not allowed. // TODO: Add role-based access for venue updates.
     * @deny (delete) Deleting venues is not allowed. // TODO: Add role-based access for venue deletion.
     * @principle Allows public read access for venue information.
     */
    match /venues/{venueId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add role-based access for venue creation.
      allow update: if false; // TODO: Add role-based access for venue updates.
      allow delete: if false; // TODO: Add role-based access for venue deletion.
    }

    /**
     * @description Controls access to experiences associated with a venue.
     * @path /venues/{venueId}/experiences/{experienceId}
     * @allow (get) Anyone can read experience information.
     * @allow (list) Anyone can list experiences.
     * @deny (create) Creating experiences is not allowed. // TODO: Add role-based access for experience creation.
     * @deny (update) Updating experiences is not allowed. // TODO: Add role-based access for experience updates.
     * @deny (delete) Deleting experiences is not allowed. // TODO: Add role-based access for experience deletion.
     * @principle Allows public read access for experiences.
     */
    match /venues/{venueId}/experiences/{experienceId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add role-based access for experience creation.
      allow update: if false; // TODO: Add role-based access for experience updates.
      allow delete: if false; // TODO: Add role-based access for experience deletion.
    }

    /**
     * @description Controls access to deals.
     * @path /deals/{dealId}
     * @allow (get) Anyone can read deal information.
     * @allow (list) Anyone can list deals.
     * @deny (create) Creating deals is not allowed.  // TODO: Add role-based access for deal creation.
     * @deny (update) Updating deals is not allowed.  // TODO: Add role-based access for deal updates.
     * @deny (delete) Deleting deals is not allowed.  // TODO: Add role-based access for deal deletion.
     * @principle Allows public read access for deals.
     */
    match /deals/{dealId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add role-based access for deal creation.
      allow update: if false; // TODO: Add role-based access for deal updates.
      allow delete: if false; // TODO: Add role-based access for deal deletion.
    }

    /**
     * @description Controls access to community information.
     * @path /communities/{communityId}
     * @allow (get) Anyone can read community information.
     * @allow (list) Anyone can list communities.
     * @deny (create) Creating communities is not allowed.  // TODO: Add role-based access for community creation based on roles in 'members' map.
     * @deny (update) Updating communities is not allowed.  // TODO: Add role-based access for community updates based on roles in 'members' map.
     * @deny (delete) Deleting communities is not allowed.  // TODO: Add role-based access for community deletion based on roles in 'members' map.
     * @principle Allows public read access for community information; implement role-based access for writes.
     */
    match /communities/{communityId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add role-based access for community creation based on roles in 'members' map.
      allow update: if false; // TODO: Add role-based access for community updates based on roles in 'members' map.
      allow delete: if false; // TODO: Add role-based access for community deletion based on roles in 'members' map.
    }

    /**
     * @description Controls access to social activities.
     * @path /socials/{socialId}
     * @allow (get) Anyone can read social activity information.
     * @allow (list) Anyone can list social activities.
     * @deny (create) Creating socials is not allowed. // TODO: Add role-based access for social creation (e.g., host).
     * @deny (update) Updating socials is not allowed. // TODO: Add role-based access for social updates (e.g., host).
     * @deny (delete) Deleting socials is not allowed. // TODO: Add role-based access for social deletion (e.g., host).
     * @principle Allows public read access for social activities; implement owner-based access for writes.
     */
    match /socials/{socialId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add role-based access for social creation (e.g., host).
      allow update: if false; // TODO: Add role-based access for social updates (e.g., host).
      allow delete: if false; // TODO: Add role-based access for social deletion (e.g., host).
    }

    /**
     * @description Controls access to participants in a social activity.
     * @path /socials/{socialId}/participants/{userId}
     * @allow (create) Any signed-in user can request to join a social activity.
     * @allow (get) Any signed-in user can read participant information.
     * @allow (list) Any signed-in user can list participants of a social activity.
     * @deny (update) Updating participants is not allowed. // TODO: Add role-based access to update participant status (e.g., host approving requests).
     * @deny (delete) Deleting participants is not allowed. // TODO: Add role-based access to remove participants (e.g., host removing).
     */
    match /socials/{socialId}/participants/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if false; // TODO: Add role-based access to update participant status (e.g., host approving requests).
      allow delete: if false;  // TODO: Add role-based access to remove participants (e.g., host removing).
    }

    /**
     * @description Controls access to stays.
     * @path /stays/{stayId}
     * @allow (get) Anyone can read stay information.
     * @allow (list) Anyone can list stays.
     * @deny (create) Creating stays is not allowed. // TODO: Add role-based access for stay creation (e.g., creators).
     * @deny (update) Updating stays is not allowed. // TODO: Add role-based access for stay updates (e.g., creators).
     * @deny (delete) Deleting stays is not allowed. // TODO: Add role-based access for stay deletion (e.g., creators).
     * @principle Allows public read access for stays; implement owner-based access for writes.
     */
    match /stays/{stayId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Add role-based access for stay creation (e.g., creators).
      allow update: if false; // TODO: Add role-based access for stay updates (e.g., creators).
      allow delete: if false; // TODO: Add role-based access for stay deletion (e.g., creators).
    }

    // --- Helper Functions ---

    /**
     * @description Checks if the request is made by a signed-in user.
     * @return True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the request is made by the owner of the resource.
     * @param {string} userId The user ID to compare with the authenticated user's ID.
     * @return True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    /**
     * @description Checks if the request is made by the owner of the resource and the resource exists.
     * @param {string} userId The user ID to compare with the authenticated user's ID.
     * @return True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isSignedIn() && isOwner(userId) && resource != null;
    }
  }
}