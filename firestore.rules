
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user's UID matches the given userId.
     * This is for checking ownership on create operations.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner of an *existing* resource.
     * This is for checking ownership on update/delete operations.
     */
    function isExistingOwner(ownerId) {
      // Check if the user is signed in, their UID matches the ownerId passed in, AND the resource exists
      return isSignedIn() && request.auth.uid == ownerId && resource != null;
    }

    /**
     * @description Checks if the user is the host of the specified social activity.
     * This function performs one read operation.
     */
    function isHost(socialId) {
      let socialDoc = get(/databases/$(database)/documents/socials/$(socialId));
      return isSignedIn() && socialDoc.data.hostId == request.auth.uid;
    }

    // --- Collection Rules ---

    // /users/{userId}
    // User profiles. Read by anyone signed in, but only writable by the owner.
    match /users/{userId} {
      // Allow any signed-in user to READ a profile for creator features, etc.
      allow get: if isSignedIn();
      // Block listing all users for security.
      allow list: if false;

      // Allow a user to create their own profile document.
      allow create: if isOwner(userId);
      
      // Allow owner to update everything, allow others to ONLY increment followerCount.
      allow update: if isExistingOwner(userId) || (
        isSignedIn() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['followerCount', 'updatedAt'])
      );
      
      allow delete: if isExistingOwner(userId);

      // Subcollections for user-specific data. Only accessible by the owner.
      match /claimedDeals/{dealId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
       match /influencedActions/{actionId} {
        allow get, list, delete: if isOwner(userId);
        allow create: if isSignedIn();
        allow update: if false;
      }
      match /joinedSocials/{socialId} {
        allow get, list, create, delete: if isOwner(userId);
        allow update: if false;
      }
      match /following/{creatorId} {
        allow get, list, create, delete: if isOwner(userId);
        allow update: if false;
      }
      match /savedStays/{stayId} {
        allow get, list, create, delete: if isOwner(userId);
        allow update: if false;
      }
    }

    // /follows/{followId}
    // Global follow relationships.
    match /follows/{followId} {
      allow get: if isSignedIn();
      allow list: if false;
      // Allow creation if the followerId matches the authenticated user.
      allow create: if isSignedIn() && request.resource.data.followerId == request.auth.uid;
      // Allow deletion if the user was the follower.
      allow delete: if isSignedIn() && resource.data.followerId == request.auth.uid;
    }

    // /venues/{venueId}
    match /venues/{venueId} {
      allow get, list: if true;
      allow delete: if false;
      allow create: if isSignedIn() && request.resource.data.slug == venueId;
      allow update: if isSignedIn();

      match /experiences/{experienceId} {
        allow get, list: if true;
        allow create, update, delete: if false;
      }
    }

    // /deals/{dealId}
    match /deals/{dealId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.creatorId);
    }
    
    // /stays/{stayId}
    match /stays/{stayId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.creatorId);
    }

    // /communities/{communityId}
    match /communities/{communityId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    // /socials/{socialId}
    match /socials/{socialId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.hostId);

      match /participants/{userId} {
        allow get, list: if true;
        allow create: if isOwner(userId);
        allow update: if isOwner(userId) || isHost(socialId);
        allow delete: if isOwner(userId) || isHost(socialId);
      }
    }

    // /sliceOfLifePosts/{postId}
    match /sliceOfLifePosts/{postId} {
        allow get, list: if true;
        allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
        allow update, delete: if isExistingOwner(resource.data.creatorId);
    }

    // /posts/{postId}
    match /posts/{postId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isExistingOwner(resource.data.creatorId);
    }

    // /claims/{claimId}
    match /claims/{claimId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // /notifications/{notificationId}
    match /notifications/{notificationId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // /classDrops/{dropId}
    // Live class drops. Discoverable by all, writable by authenticated instructors/users.
    match /classDrops/{dropId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // /savedVenues/{saveId}
    match /savedVenues/{saveId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isOwner(request.resource.data.userId);
    }

    // /savedStyle/{saveId}
    match /savedStyle/{saveId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isOwner(request.resource.data.userId);
    }

    // /savedDeals/{saveId}
    match /savedDeals/{saveId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isOwner(request.resource.data.userId);
    }

    // /savedStays/{saveId}
    match /savedStays/{saveId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isOwner(request.resource.data.userId);
    }

    // /venueRequests/{requestId}
    match /venueRequests/{requestId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // /userPlans/{planId}
    match /userPlans/{planId} {
      allow read, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create, update: if isOwner(request.resource.data.userId);
    }

    // /hotItems/{itemId}
    // Fire drops (venue offers). Public read; writes via signed-in sessions
    // (the /admin seeder). TODO: tighten to admin-only before scale.
    match /hotItems/{itemId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    // /tableDrops/{dropId}
    match /tableDrops/{dropId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
