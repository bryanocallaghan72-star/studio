rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    /**
     * @description Checks if a user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }
    
    /**
     * @description Checks if the user is the owner of the resource being created.
     * Use for 'create' operations.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    /**
     * @description Checks if the user is the owner of the existing resource.
     * Use for 'update' and 'delete' operations on documents that have an owner field.
     */
    function isExistingOwner(userId) {
      return isSignedIn() && request.auth.uid == userId && resource.data.id == userId;
    }

    /**
     * @description Checks if the user is the host of the specified social event.
     * This function performs one read operation.
     */
    function isHost(socialId) {
      let socialDoc = get(/databases/$(database)/documents/socials/$(socialId));
      return isSignedIn() && socialDoc.data.hostId == request.auth.uid;
    }

    // =====================================================================
    // User Profiles
    // =====================================================================
    match /users/{userId} {
      // Allow any signed-in user to READ a profile for creator features.
      allow get: if isSignedIn();
      
      // Block anyone from LISTING all users.
      allow list: if false;

      // Write access is restricted to the owner of the profile.
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);

      // --- Subcollections for user-specific actions ---
      match /claimedDeals/{dealId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if false; // No update logic needed for this record
        allow delete: if isOwner(userId); // User can un-claim a deal
      }
      
      match /joinedSocials/{socialId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if false; // No update logic needed for this record
        allow delete: if isOwner(userId); // User can leave a social
      }

      match /following/{creatorId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if false; // No update logic needed for this record
        allow delete: if isOwner(userId); // User can unfollow a creator
      }

      match /savedStays/{stayId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if false; // No update logic needed for this record
        allow delete: if isOwner(userId); // User can unsave a stay
      }
    }
    
    // =====================================================================
    // Public & Creator-Led Collections
    // =====================================================================
    match /venues/{venueId} {
      allow get: if true;
      allow list: if true;

      // Only creators can add/edit venues
      allow create: if false; // Not allowing frontend creation for now
      allow update: if false;
      allow delete: if false;
    }
    
    match /deals/{dealId} {
      allow get: if true;
      allow list: if true;

      // Only the creator who owns the deal can manage it
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.creatorId);
      allow delete: if isExistingOwner(resource.data.creatorId);
    }

    match /stays/{stayId} {
      allow get: if true;
      allow list: if true;

      // Only the creator who owns the stay can manage it
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.creatorId);
      allow delete: if isExistingOwner(resource.data.creatorId);
    }
    
    // =====================================================================
    // Social & Community Collections
    // =====================================================================
    match /socials/{socialId} {
      allow get: if true;
      allow list: if true;
      
      // Any signed-in user can create a social event
      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      // Only the host can update or delete the event
      allow update: if isExistingOwner(resource.data.hostId);
      allow delete: if isExistingOwner(resource.data.hostId);
      
      // --- Subcollection for managing participants ---
      match /participants/{userId} {
        allow get: if true;
        allow list: if true;
        
        // A user can create their own request to join.
        allow create: if isOwner(userId);
        // A user can update their own status (e.g. leave), OR the host can update it (e.g. accept).
        allow update: if isOwner(userId) || isHost(socialId);
        // A user can delete their own record, OR the host can remove them.
        allow delete: if isOwner(userId) || isHost(socialId);
      }
    }

    match /communities/{communityId} {
      allow get: if true;
      allow list: if true;

      // Community management is not yet implemented on the client
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}