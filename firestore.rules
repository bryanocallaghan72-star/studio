/**
 * @fileoverview Firestore Security Rules for the iykyk application.
 *
 * Core Philosophy:
 * This ruleset prioritizes user data ownership and secure collaboration through denormalization and clear access control patterns.
 *
 * Data Structure:
 * - User profiles are stored under `/users/{userId}`, with user-specific data in subcollections.
 * - Venues, deals, communities, socials, and stays are stored in top-level collections for efficient querying.
 *
 * Key Security Decisions:
 * - Users can read other user profiles, but only modify their own.
 * - Data required for authorization is denormalized to avoid costly `get()` calls.
 * - Public read access is granted cautiously, only when the collection's data is intended for all users (e.g., venues, deals, stays).
 * - All write operations are protected by authorization checks.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Manages user profiles and their associated data.
     * @path /users/{userId}
     * @allow (get) Signed-in user can read any user profile.
     * @allow (create) User can create their own profile if the user ID matches auth.
     * @allow (update) User can update their own profile if the user ID matches auth.
     * @allow (delete) User can delete their own profile if the user ID matches auth.
     * @deny (list) Listing all users is prohibited.
     * @deny (create) User cannot create a profile with an ID different than their own.
     * @deny (update) User cannot update a profile with an ID different than their own.
     * @deny (delete) User cannot delete a profile that doesn't exist, or belongs to another user.
     * @principle Enforces document ownership for writes, allows public reads for profiles.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Tracks deals claimed by a user.
     * @path /users/{userId}/claimedDeals/{dealId}
     * @allow (get) User can read their own claimed deals.
     * @allow (list) User can list their own claimed deals.
     * @allow (create) User can create a record of claiming a deal.
     * @allow (update) Denied. Claimed deals cannot be updated.
     * @allow (delete) User can delete a record of claiming a deal.
     * @deny User cannot access claimed deals of other users.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/claimedDeals/{dealId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if isOwner(userId);
    }

    /**
     * @description Tracks social activities a user has joined.
     * @path /users/{userId}/joinedSocials/{socialId}
     * @allow (get) User can read their own joined socials.
     * @allow (list) User can list their own joined socials.
     * @allow (create) User can create a record of joining a social.
     * @allow (update) Denied. Joined socials records cannot be updated.
     * @allow (delete) User can delete a record of joining a social.
     * @deny User cannot access joined socials of other users.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/joinedSocials/{socialId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if isOwner(userId);
    }

    /**
     * @description Tracks creators a user is following.
     * @path /users/{userId}/following/{creatorId}
     * @allow (get) User can read their own following records.
     * @allow (list) User can list their own following records.
     * @allow (create) User can create a record of following a creator.
     * @allow (update) Denied. Following records cannot be updated.
     * @allow (delete) User can delete a record of following a creator.
     * @deny User cannot access following records of other users.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/following/{creatorId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if isOwner(userId);
    }

    /**
     * @description Tracks stays a user has saved.
     * @path /users/{userId}/savedStays/{stayId}
     * @allow (get) User can read their own saved stays.
     * @allow (list) User can list their own saved stays.
     * @allow (create) User can create a record of saving a stay.
     * @allow (update) Denied. Saved stay records cannot be updated.
     * @allow (delete) User can delete a record of saving a stay.
     * @deny User cannot access saved stays of other users.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/savedStays/{stayId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if isOwner(userId);
    }

    /**
     * @description Stores venue information. Publicly readable.
     * @path /venues/{venueId}
     * @allow (get, list) Any signed-in user can read venue information.
     * @allow (create, update, delete) No one can create, update, or delete venues through client-side rules.
     * @principle Public read access for venue information.
     */
    match /venues/{venueId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Stores experiences associated with a venue.
     * @path /venues/{venueId}/experiences/{experienceId}
     * @allow (get, list) Any signed-in user can read experience information.
     * @allow (create, update, delete) No one can create, update, or delete experiences through client-side rules.
     * @principle Public read access for experience information.
     */
    match /venues/{venueId}/experiences/{experienceId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description A denormalized, top-level collection for all deals. Publicly readable.
     * @path /deals/{dealId}
     * @allow (get, list) Any signed-in user can read deal information.
     * @allow (create, update, delete) No one can create, update, or delete deals through client-side rules.
     * @principle Public read access for deal information.
     */
    match /deals/{dealId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Stores community information with role-based access control.
     * @path /communities/{communityId}
     */
    match /communities/{communityId} {
        allow get: if true;
        allow list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description A top-level collection for user-created social activities.
     * @path /socials/{socialId}
     */
    match /socials/{socialId} {
        allow get: if true;
        allow list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    /**
     * @description Manages participants for a specific social activity.
     * @path /socials/{socialId}/participants/{userId}
     */
    match /socials/{socialId}/participants/{userId} {
        allow get: if true;
        allow list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

     /**
      * @description A top-level collection for all creator-recommended stays.
      * @path /stays/{stayId}
      */
    match /stays/{stayId} {
        allow get: if true;
        allow list: if true;
        allow create: if false;
        allow update: if false;
        allow delete: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }
  }
}