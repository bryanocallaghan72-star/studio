/**
 * @fileoverview Firestore Security Rules for the iykyk platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for personal data
 * while allowing public read access to venue, deal, community, social activity, and stay information.
 * Write access to these public entities is restricted based on ownership or role.
 *
 * Data Structure:
 * - /users/{userId}: User profiles and user-specific data.
 * - /venues/{venueId}: Venue information.
 * - /deals/{dealId}: Deals and promotions.
 * - /communities/{communityId}: Communities with role-based access control.
 * - /socials/{socialId}: User-created social activities.
 * - /stays/{stayId}: Stays recommended by creators.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect user privacy.
 * - Public read access is granted to venue, deal, community, social activity, and stay data to enable discovery.
 * - Write access to venue, deal, social activity, and stay data is based on ownership or role.
 *
 * Denormalization for Authorization:
 * The data model denormalizes the venueName into the Deals collection, and hostUsername into the SocialActivity collection, to allow for efficient queries and authorization rules without additional `get()` calls.
 *
 * Structural Segregation:
 * Private user data is stored under /users/{userId}, while public data resides in top-level collections. This separation ensures that public and private data have distinct security postures.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     * @returns {boolean} True if the user is signed in, false otherwise.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's ID matches the provided user ID.
     * @param {string} userId The user ID to compare against.
     * @returns {boolean} True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner and the resource exists.
     * @param {string} userId The user ID to compare against.
     * @returns {boolean} True if the user is the owner and the resource exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rules for user profiles and associated data.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile if authenticated as 'user123'.
     * @allow (get, update, delete) User with ID 'user123' can access/modify their profile if authenticated as 'user123'.
     * @deny (get, update, delete) User with ID 'user456' cannot access/modify profile 'user123' if authenticated as 'user456'.
     * @principle Enforces document ownership for user profiles.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // User listing is not permitted.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id; // Enforce immutability of userId on update
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for deals claimed by a user.
       * @path /users/{userId}/claimedDeals/{dealId}
       * @allow (create) User with ID 'user123' can create a claimedDeal under their profile if authenticated as 'user123'.
       * @allow (get, update, delete) User with ID 'user123' can access/modify a claimedDeal under their profile if authenticated as 'user123'.
       * @deny (get, update, delete) User with ID 'user456' cannot access/modify claimedDeal 'deal789' under profile 'user123' if authenticated as 'user456'.
       * @principle Enforces document ownership for claimed deals.
       */
      match /claimedDeals/{dealId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for social activities joined by a user.
       * @path /users/{userId}/joinedSocials/{socialId}
       * @allow (create) User with ID 'user123' can create a joinedSocial under their profile if authenticated as 'user123'.
       * @allow (get, update, delete) User with ID 'user123' can access/modify a joinedSocial under their profile if authenticated as 'user123'.
       * @deny (get, update, delete) User with ID 'user456' cannot access/modify joinedSocial 'social789' under profile 'user123' if authenticated as 'user456'.
       * @principle Enforces document ownership for joined socials.
       */
      match /joinedSocials/{socialId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for creators followed by a user.
       * @path /users/{userId}/following/{creatorId}
       * @allow (create) User with ID 'user123' can create a following record under their profile if authenticated as 'user123'.
       * @allow (get, update, delete) User with ID 'user123' can access/modify a following record under their profile if authenticated as 'user123'.
       * @deny (get, update, delete) User with ID 'user456' cannot access/modify following record 'creator789' under profile 'user123' if authenticated as 'user456'.
       * @principle Enforces document ownership for following records.
       */
      match /following/{creatorId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }

       /**
       * @description Rules for stays saved by a user.
       * @path /users/{userId}/savedStays/{stayId}
       * @allow (create) User with ID 'user123' can create a savedStay under their profile if authenticated as 'user123'.
       * @allow (get, update, delete) User with ID 'user123' can access/modify a savedStay under their profile if authenticated as 'user123'.
       * @deny (get, update, delete) User with ID 'user456' cannot access/modify savedStay 'stay789' under profile 'user123' if authenticated as 'user456'.
       * @principle Enforces document ownership for saved stays.
       */
      match /savedStays/{stayId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for venues.
     * @path /venues/{venueId}
     * @allow (get, list) Anyone can read venue information.
     * @principle Allows public read access to venues.
     */
    match /venues/{venueId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.

      /**
       * @description Rules for experiences associated with a venue.
       * @path /venues/{venueId}/experiences/{experienceId}
       * @allow (get, list) Anyone can read experience information.
       * @principle Allows public read access to experiences.
       */
      match /experiences/{experienceId} {
        allow get: if true;
        allow list: if true;
        allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
      }
    }

    /**
     * @description Rules for deals.
     * @path /deals/{dealId}
     * @allow (get, list) Anyone can read deal information.
     * CRITICAL: Cannot implement owner-only writes. The 'Deal' entity is missing an 'ownerId' or 'authorId' field.
     * @principle Allows public read access to deals.
     */
    match /deals/{dealId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Rules for communities.
     * @path /communities/{communityId}
     * @allow (get, list) Anyone can read community information.
     * @principle Allows public read access to communities.
     */
    match /communities/{communityId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Rules for social activities.
     * @path /socials/{socialId}
     * @allow (get, list) Anyone can read social activity information.
     * CRITICAL: Cannot implement owner-only writes. The 'SocialActivity' entity is missing an 'ownerId' or 'authorId' field.
     * @principle Allows public read access to social activities.
     */
    match /socials/{socialId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.

      /**
       * @description Rules for participants in a social activity.
       * @path /socials/{socialId}/participants/{userId}
       * @allow (create) User with ID 'user123' can create their participant record in social activity 'social456' if authenticated as 'user123'.
       * @allow (get, update, delete) User with ID 'user123' can access/modify their participant record in social activity 'social456' if authenticated as 'user123'.
       * @deny (get, update, delete) User with ID 'user456' cannot access/modify participant record 'user123' in social activity 'social456' if authenticated as 'user456'.
       * @principle Enforces document ownership for social activity participants.
       */
      match /participants/{userId} {
        allow get: if true;
        allow list: if true;
        allow create: if isSignedIn() && request.auth.uid == userId;
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for stays.
     * @path /stays/{stayId}
     * @allow (get, list) Anyone can read stay information.
     * CRITICAL: Cannot implement owner-only writes. The 'Stay' entity is missing an 'ownerId' or 'authorId' field.
     * @principle Allows public read access to stays.
     */
    match /stays/{stayId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }
  }
}