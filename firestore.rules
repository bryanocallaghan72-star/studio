/**
 * @fileoverview Firestore Security Rules for iykyk platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles,
 * and role-based access control for communities. Venues and their associated
 * experiences and deals are publicly readable but writable only with proper authorization.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only by the owning user.
 * - /venues/{venueId}: Stores venue information, publicly readable.
 * - /venues/{venueId}/experiences/{experienceId}: Stores experiences, publicly readable.
 * - /venues/{venueId}/deals/{dealId}: Stores deals, publicly readable.
 * - /communities/{communityId}: Stores community information, with role-based access.
 *
 * Key Security Decisions:
 * - Users can only read and write their own user profile data.
 * - Venues, experiences, and deals are publicly readable, but write access requires
 *   validation of an ownership field (creatorId for deals).
 * - Communities use a `members` map for role-based access control.
 * - Listing of user documents is disallowed for privacy.
 *
 * Denormalization for Authorization:
 * - Experiences and Deals denormalize the `venueId` to allow authorization
 *   checks without needing to perform `get()` operations on the parent venue document.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for user profiles.
     * @path /users/{userId}
     * @allow (get, create, update, delete, list) User 'lucas' (auth.uid = 'lucas') can access their own profile.
     * @deny (get, create, update, delete, list) User 'other' (auth.uid = 'other') cannot access user 'lucas' profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && exists(resource);
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && isExistingOwner(userId);
      allow delete: if isSignedIn() && isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to venue information.
     * @path /venues/{venueId}
     * @allow (get, list) Any user (or no user) can read venue information.
     * @deny (create, update, delete) No one can create, update, or delete venues in this prototyping phase.
     * @principle Allows public reads, restricts writes.
     */
    match /venues/{venueId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows public read access to experience information.
     * @path /venues/{venueId}/experiences/{experienceId}
     * @allow (get, list) Any user (or no user) can read experience information.
     * @deny (create, update, delete) No one can create, update, or delete experiences in this prototyping phase.
     * @principle Allows public reads, restricts writes.
     */
    match /venues/{venueId}/experiences/{experienceId} {
      allow get, list: if true;
      allow create, update, delete: if false; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Allows public read access to deal information, restricts writes to authorized users.
     * @path /venues/{venueId}/deals/{dealId}
     * @allow (get, list) Any user can read deal information.
     * @deny (create, update, delete) If creatorId is missing or does not match the authenticated user's ID.
     * @principle Allows public reads, restricts writes to deal creators.
     */
    match /venues/{venueId}/deals/{dealId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(creatorId) {
        return isSignedIn() && request.auth.uid == creatorId;
      }

      function isExistingOwner(creatorId) {
          return isSignedIn() && resource.data.creatorId == request.auth.uid && exists(resource);
      }

      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.creatorId);
      allow delete: if isExistingOwner(resource.data.creatorId);
    }

    /**
     * @description Enforces role-based access control for communities.
     * @path /communities/{communityId}
     * @allow (get, list) Any user can read community information.
     * @deny (create, update, delete) Only community members with specific roles can modify community details.
     * @principle Enforces role-based access using a 'members' map.
     */
    match /communities/{communityId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isMember(communityId) {
        return isSignedIn() && get(/databases/$(database)/documents/communities/$(communityId)).data.members[request.auth.uid] != null;
      }

      allow get, list: if true;
      allow create: if false; // TODO: Add role-based validation once the schema and roles are properly defined.
      allow update: if false; // TODO: Add role-based validation once the schema and roles are properly defined.
      allow delete: if false; // TODO: Add role-based validation once the schema and roles are properly defined.
    }
  }
}