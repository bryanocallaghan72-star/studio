/**
 * @fileoverview Firestore Security Rules for the iykyk platform.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for personal data stored under the `/users/{userId}` path.
 * Top-level collections like `/venues`, `/deals`, `/communities`, `/socials`, and `/stays` are designed for public readability with restricted write access.
 * Rules are designed to be secure by default, erring on the side of denial unless explicitly allowed.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles and associated data.
 *   - /users/{userId}/claimedDeals/{dealId}: Tracks deals claimed by a user.
 *   - /users/{userId}/joinedSocials/{socialId}: Tracks social activities a user has joined.
 *   - /users/{userId}/following/{creatorId}: Tracks creators a user is following.
 *   - /users/{userId}/savedStays/{stayId}: Tracks stays a user has saved.
 * - /venues/{venueId}: Stores venue information.
 *   - /venues/{venueId}/experiences/{experienceId}: Stores experiences related to a venue.
 * - /deals/{dealId}: Stores deal information.
 * - /communities/{communityId}: Stores community information.
 * - /socials/{socialId}: Stores social activity information.
 *   - /socials/{socialId}/participants/{userId}: Stores participant information for a social activity.
 * - /stays/{stayId}: Stores stay information.
 *
 * Key Security Decisions:
 * - User data is strictly controlled by the owning user.
 * - Public listing of user documents is disallowed.
 * - Top-level collections are generally readable by anyone, but writes are restricted.
 * - All write operations require authentication.
 * - Deletes are only allowed by the owner of the document.
 *
 * Denormalization for Authorization:
 *  - Data required for authorization (e.g., ownership) is denormalized directly onto documents to avoid costly `get()` calls in security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the request is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the resource.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the owner of the existing resource.
     *             This function should be used for update and delete operations.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces user-ownership for all documents under /users/{userId}.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user123' can create their own profile document.
     * @allow (get, list) - User with UID 'user123' can read their own profile document.
     * @deny (create) - User with UID 'user456' cannot create a profile document for 'user123'.
     * @deny (update, delete) - Only the owner can update or delete their profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Prevent listing all users

      allow create: if isOwner(userId) && request.resource.data.id == request.auth.uid;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for claimed deals under /users/{userId}/claimedDeals/{dealId}.
     * @path /users/{userId}/claimedDeals/{dealId}
     * @allow (create) - User with UID 'user123' can create a claimed deal document under their profile.
     * @allow (get, list) - User with UID 'user123' can read claimed deals under their profile.
     * @allow (delete) - User with UID 'user123' can delete a claimed deal document under their profile.
     * @deny (create) - User with UID 'user456' cannot create a claimed deal document for 'user123'.
     * @deny (update) - Claimed deals cannot be updated.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/claimedDeals/{dealId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if false; // This is fine, they don't need to update it
      allow delete: if isExistingOwner(userId); // <-- Let the owner delete it
    }

    /**
     * @description Enforces user-ownership for joined socials under /users/{userId}/joinedSocials/{socialId}.
     * @path /users/{userId}/joinedSocials/{socialId}
     * @allow (create) - User with UID 'user123' can create a joined social document under their profile.
     * @allow (get, list) - User with UID 'user123' can read joined socials under their profile.
     * @allow (delete) - User with UID 'user123' can delete a joined social document under their profile.
     * @deny (create) - User with UID 'user456' cannot create a joined social document for 'user123'.
     * @deny (update) - Joined socials cannot be updated.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/joinedSocials/{socialId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if false; // This is fine, they don't need to update it
      allow delete: if isExistingOwner(userId); // <-- Let the owner delete it
    }

    /**
     * @description Enforces user-ownership for following under /users/{userId}/following/{creatorId}.
     * @path /users/{userId}/following/{creatorId}
     * @allow (create) - User with UID 'user123' can create a following document under their profile.
     * @allow (get, list) - User with UID 'user123' can read following documents under their profile.
     * @allow (delete) - User with UID 'user123' can delete a following document under their profile.
     * @deny (create) - User with UID 'user456' cannot create a following document for 'user123'.
     * @deny (update) - Following documents cannot be updated.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/following/{creatorId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if false; // This is fine, they don't need to update it
      allow delete: if isExistingOwner(userId); // <-- Let the owner delete it
    }

    /**
     * @description Enforces user-ownership for saved stays under /users/{userId}/savedStays/{stayId}.
     * @path /users/{userId}/savedStays/{stayId}
     * @allow (create) - User with UID 'user123' can create a saved stay document under their profile.
     * @allow (get, list) - User with UID 'user123' can read saved stays under their profile.
     * @allow (delete) - User with UID 'user123' can delete a saved stay document under their profile.
     * @deny (create) - User with UID 'user456' cannot create a saved stay document for 'user123'.
     * @deny (update) - Saved stays cannot be updated.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/savedStays/{stayId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if false; // This is fine, they don't need to update it
      allow delete: if isExistingOwner(userId); // <-- Let the owner delete it
    }

    /**
     * @description Allows public read access to venue information, but restricts writes.
     * @path /venues/{venueId}
     * @allow (get, list) - Any user can read venue information.
     * @deny (create, update, delete) - Only authorized users (e.g., admins) can modify venue data.
     * @principle Public read, restricted write access.
     */
    match /venues/{venueId} {
      allow get: if true;
      allow list: if true;

      allow create: if false; // TODO: Add creator/admin validation
      allow update: if false; // TODO: Add creator/admin validation
      allow delete: if false; // TODO: Add creator/admin validation
    }

    /**
     * @description Allows public read access to experiences associated with a venue, but restricts writes.
     * @path /venues/{venueId}/experiences/{experienceId}
     * @allow (get, list) - Any user can read experience information.
     * @deny (create, update, delete) - Only authorized users can modify experience data.
     * @principle Public read, restricted write access.
     */
    match /venues/{venueId}/experiences/{experienceId} {
      allow get: if true;
      allow list: if true;

      allow create: if false; // TODO: Add creator/admin validation
      allow update: if false; // TODO: Add creator/admin validation
      allow delete: if false; // TODO: Add creator/admin validation
    }

    /**
     * @description Allows public read access to deals, but restricts writes.
     * @path /deals/{dealId}
     * @allow (get, list) - Any user can read deal information.
     * @deny (create, update, delete) - Only authorized users can modify deal data.
     * @principle Public read, restricted write access.
     */
    match /deals/{dealId} {
      allow get: if true;
      allow list: if true;

      allow create: if false; // TODO: Add creator/admin validation
      allow update: if false; // TODO: Add creator/admin validation
      allow delete: if false; // TODO: Add creator/admin validation
    }

    /**
     * @description Allows public read access to community information, but restricts writes to authorized users.
     * @path /communities/{communityId}
     * @allow (get, list) - Any user can read community information.
     * @deny (create, update, delete) - Only authorized users can modify community data.
     * @principle Public read, restricted write access with potential for role-based access via the `members` map.
     */
    match /communities/{communityId} {
      allow get: if true;
      allow list: if true;

      allow create: if false; // TODO: Add creator/admin validation
      allow update: if false; // TODO: Add creator/admin validation
      allow delete: if false; // TODO: Add creator/admin validation
    }

    /**
     * @description Allows public read access to social activity information, but restricts writes to authorized users.
     * @path /socials/{socialId}
     * @allow (get, list) - Any user can read social activity information.
     * @deny (create, update, delete) - Only the host of the social activity or an admin can modify it.
     * @principle Public read, restricted write access.
     */
    match /socials/{socialId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn(); // Only signed-in users can create social activities.
      allow update: if false; // TODO: Add creator/admin validation
      allow delete: if false; // TODO: Add creator/admin validation
    }

    /**
     * @description Manages participants for a specific social activity.
     * @path /socials/{socialId}/participants/{userId}
     * @allow (get, list) - Any user can read the list of participants in a social activity.
     * @allow (create) - A user can create their own participant document to request or join.
     * @deny (update, delete) - Modifying or deleting participant entries is not allowed (status changes handled via backend functions).
     * @principle Shared access with restrictions on modifications.
     */
    match /socials/{socialId}/participants/{userId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if false; // Updates are disallowed.
      allow delete: if false; // Deletes are disallowed.
    }

    /**
     * @description Allows public read access to stay information, but restricts writes.
     * @path /stays/{stayId}
     * @allow (get, list) - Any user can read stay information.
     * @deny (create, update, delete) - Only authorized users can modify stay data.
     * @principle Public read, restricted write access.
     */
    match /stays/{stayId} {
      allow get: if true;
      allow list: if true;

      allow create: if false; // TODO: Add creator/admin validation
      allow update: if false; // TODO: Add creator/admin validation
      allow delete: if false; // TODO: Add creator/admin validation
    }
  }
}