/**
 * @description This ruleset enforces a combination of user-ownership, role-based access for "Creators", and public read access for certain collections.
 * Data Structure:
 * - /users/{userId}:  User profiles and associated data (claimed deals, joined socials, followed creators, saved stays).  Access is restricted to the owning user.
 * - /venues/{venueId}: Venue information.
 * - /venues/{venueId}/experiences/{experienceId}: Experiences at a venue.
 * - /deals/{dealId}: Deals and "Fire" items. Access is restricted to "Creators".
 * - /communities/{communityId}: Communities with role-based access via a "members" map.
 * - /socials/{socialId}: Social activities, with open creation and host-based update/delete permissions.
 * - /socials/{socialId}/participants/{userId}: Social activity participant management.
 * - /stays/{stayId}: Creator-recommended stays. Access is restricted to "Creators".
 *
 * Key Security Decisions:
 * - "Creator" role is managed via custom claims ("isCreator": true).
 * - Deals, Venues, and Stays are restricted to Creators only.
 * - Socials are creatable by any signed-in user, but can only be modified/deleted by the host.
 * - Participants of a Socials can manage their own participation.
 * - User profiles are readable by any signed-in user.
 * - Public listing is enabled for deals, venues, socials, and stays.
 *
 * Denormalization for Authorization:
 * - The `SocialActivity` entity contains denormalized `hostId` for access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is a verified Creator.
     * This rule checks for a custom claim on the user's auth token.
     */
    function isCreator() {
      return isSignedIn() && request.auth.token.isCreator == true;
    }

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user is the owner of the document.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the document.
     * This is used for update and delete operations to ensure the document exists and the user is the owner.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Rule for user profiles.
     * @path /users/{userId}
     * @allow (create) A user with ID 'user123' creates their own profile with id: 'user123'.
     * @allow (update) A user with ID 'user123' updates their own profile.
     * @allow (delete) A user with ID 'user123' deletes their own profile.
     * @deny (create) A user with ID 'user123' tries to create a profile with id: 'user456'.
     * @principle Enforces document ownership for writes and allows public reads.
     */
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule for claimed deals under a user.
     * @path /users/{userId}/claimedDeals/{dealId}
     * @allow (create) A user with ID 'user123' claims a deal.
     * @allow (update) A user with ID 'user123' updates a claimed deal.
     * @allow (delete) A user with ID 'user123' deletes a claimed deal.
     * @deny (create) A user with ID 'user123' tries to claim a deal for another user.
     * @principle Enforces document ownership.
     */
    match /users/{userId}/claimedDeals/{dealId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule for joined socials under a user.
     * @path /users/{userId}/joinedSocials/{socialId}
     * @allow (create) A user with ID 'user123' records that they have joined a social.
     * @allow (update) A user with ID 'user123' updates a joined social record.
     * @allow (delete) A user with ID 'user123' deletes a joined social record.
     * @deny (create) A user with ID 'user123' tries to record a joined social for another user.
     * @principle Enforces document ownership.
     */
    match /users/{userId}/joinedSocials/{socialId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule for following creators under a user.
     * @path /users/{userId}/following/{creatorId}
     * @allow (create) A user with ID 'user123' follows a creator.
     * @allow (update) A user with ID 'user123' updates a following record.
     * @allow (delete) A user with ID 'user123' unfollows a creator.
     * @deny (create) A user with ID 'user123' tries to follow a creator for another user.
     * @principle Enforces document ownership.
     */
    match /users/{userId}/following/{creatorId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule for saved stays under a user.
     * @path /users/{userId}/savedStays/{stayId}
     * @allow (create) A user with ID 'user123' saves a stay.
     * @allow (update) A user with ID 'user123' updates a saved stay record.
     * @allow (delete) A user with ID 'user123' unsaves a stay.
     * @deny (create) A user with ID 'user123' tries to save a stay for another user.
     * @principle Enforces document ownership.
     */
    match /users/{userId}/savedStays/{stayId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Rule for venues.
     * @path /venues/{venueId}
     * @allow (get) Any user can get venue information.
     * @allow (list) Any user can list venues.
     * @allow (create) A creator can create a venue.
     * @allow (update) A creator can update a venue.
     * @allow (delete) A creator can delete a venue.
     * @principle Allows public reads and creator-only writes.
     */
    match /venues/{venueId} {
      allow get: if true;
      allow list: if true;
      allow create: if isCreator();
      allow update: if isCreator();
      allow delete: if isCreator();
    }

    /**
     * @description Rule for experiences under a venue.
     * @path /venues/{venueId}/experiences/{experienceId}
     * @allow (get) Any user can get experience information.
     * @allow (list) Any user can list experiences.
     * @deny (create) No one can create an experience directly.
     * @deny (update) No one can update an experience directly.
     * @deny (delete) No one can delete an experience directly.
     * @principle Denies all writes directly, likely managed via backend functions.
     */
    match /venues/{venueId}/experiences/{experienceId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rule for deals.
     * @path /deals/{dealId}
     * @allow (get) Any user can get deal information.
     * @allow (list) Any user can list deals.
     * @allow (create) A creator can create a deal.
     * @allow (update) A creator can update a deal.
     * @allow (delete) A creator can delete a deal.
     * @principle Allows public reads and creator-only writes.
     */
    match /deals/{dealId} {
      allow get: if true;
      allow list: if true;
      allow create: if isCreator();
      allow update: if isCreator();
      allow delete: if isCreator();
    }

    /**
     * @description Rule for communities.
     * @path /communities/{communityId}
     * @allow (get) Any user can get community information.
     * @allow (list) Any user can list communities.
     * @deny (create) No one can create a community directly.
     * @deny (update) No one can update a community directly.
     * @deny (delete) No one can delete a community directly.
     * @principle Denies all writes directly, likely managed via backend functions.
     */
    match /communities/{communityId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Rule for socials.
     * @path /socials/{socialId}
     * @allow (get) Any user can get social information.
     * @allow (list) Any user can list socials.
     * @allow (create) Any signed-in user can create a social.
     * @allow (update) Only the host can update the social.
     * @allow (delete) Only the host can delete the social.
     * @principle Allows open creation and host-based management.
     */
    match /socials/{socialId} {
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isOwner(request.resource.data.hostId);
      allow delete: if isOwner(resource.data.hostId);
    }

    /**
     * @description Rule for social participants.
     * @path /socials/{socialId}/participants/{userId}
     * @allow (get) Any user can get participant information.
     * @allow (list) Any user can list participants.
     * @allow (create) A user can only "ask to join" as themselves.
     * @allow (update) A user can update their own status (e.g., to "joined"). Host can also update statuses
     * @allow (delete) A user can leave the group.
     * @principle Enforces user-managed participation.
     */
    match /socials/{socialId}/participants/{userId} {
      allow get: if true;
      allow list: if true;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Rule for stays.
     * @path /stays/{stayId}
     * @allow (get) Any user can get stay information.
     * @allow (list) Any user can list stays.
     * @allow (create) A creator can create a stay.
     * @allow (update) A creator can update a stay.
     * @allow (delete) A creator can delete a stay.
     * @principle Allows public reads and creator-only writes.
     */
    match /stays/{stayId} {
      allow get: if true;
      allow list: if true;
      allow create: if isCreator();
      allow update: if isCreator();
      allow delete: if isCreator();
    }
  }
}