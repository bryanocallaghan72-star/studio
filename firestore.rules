/**
 * @fileoverview Firestore Security Rules for iykyk Platform
 *
 * Core Philosophy:
 * This ruleset enforces a user-ownership model for personal data and a role-based model for collaborative entities like communities and social activities. It prioritizes security by default, explicitly denying access unless specifically granted. It leverages denormalization to avoid costly `get()` calls within rules.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles and personal data.
 * - /venues/{venueId}: Stores venue information.
 * - /venues/{venueId}/experiences/{experienceId}: Stores experiences at a venue.
 * - /deals/{dealId}: Stores deals and 'Fire' items for efficient global querying.
 * - /communities/{communityId}: Stores community data with a 'members' map for access control.
 * - /socials/{socialId}: Stores social activity information.
 * - /socials/{socialId}/participants/{userId}: Stores participation status for social activities.
 * - /stays/{stayId}: Stores creator-recommended stays and flash stays.
 *
 * Key Security Decisions:
 * - Users can only access and modify their own data under /users/{userId}.
 * - Public read access is granted to venues, deals, communities, socials, and stays for discovery.
 * - Only the creator of a deal or stay can modify it.
 * - Communities use a members map to control access.
 * - Social activities have a host who can manage participants.
 * - Listing of user subcollections (claimedDeals, joinedSocials, following, savedStays) is allowed only for the owner.
 *
 * Denormalization for Authorization:
 * - The deals collection denormalizes venueName to allow for queries without requiring a get() operation.
 * - The SocialActivity collection denormalizes hostUsername to allow for display without requiring a get() operation.
 * - Stays denormalize creatorName and creatorAvatarUrl for efficient querying.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the owner of the specified resource.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the existing owner of the specified resource.
     * This function requires that the resource already exists.
     */
    function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
    }

    /**
     * @description Checks if the user is the host of the specified social.
     * This function performs one read operation.
     */
    function isHost(socialId) {
      let socialDoc = get(/databases/$(database)/documents/socials/$(socialId));
      return isSignedIn() && socialDoc.data.hostId == request.auth.uid;
    }

    /**
     * @description Enforces access control for user profiles.
     * @path /users/{userId}
     * @allow (create) - If the user's ID matches the requested userId.
     * @allow (get, list, update, delete) - If the user is the owner of the profile.
     * @deny (create) - If the user's ID does not match the requested userId.
     * @deny (update, delete) - If the user is not the owner of the profile.
     * @principle Enforces document ownership for writes.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;

      allow create: if isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces access control for claimed deals within a user's profile.
     * @path /users/{userId}/claimedDeals/{dealId}
     * @allow (create, get, list) - If the user is the owner of the profile.
     * @deny (update, delete) - Only the user can create/read their claimed deals. Updates/deletes are disallowed for simplicity.
     * @deny (create) - If the user is not the owner of the profile.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/claimedDeals/{dealId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Enforces access control for joined socials within a user's profile.
     * @path /users/{userId}/joinedSocials/{socialId}
     * @allow (create, get, list) - If the user is the owner of the profile.
     * @deny (update, delete) - Only the user can create/read their joined socials. Updates/deletes are disallowed for simplicity.
     * @deny (create) - If the user is not the owner of the profile.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/joinedSocials/{socialId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Enforces access control for followed creators within a user's profile.
     * @path /users/{userId}/following/{creatorId}
     * @allow (create, get, list) - If the user is the owner of the profile.
     * @deny (update, delete) - Only the user can create/read their following. Updates/deletes are disallowed for simplicity.
     * @deny (create) - If the user is not the owner of the profile.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/following/{creatorId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

     /**
     * @description Enforces access control for saved stays within a user's profile.
     * @path /users/{userId}/savedStays/{stayId}
     * @allow (create, get, list) - If the user is the owner of the profile.
     * @deny (update, delete) - Only the user can create/read their saved stays. Updates/deletes are disallowed for simplicity.
     * @deny (create) - If the user is not the owner of the profile.
     * @principle Restricts access to a user's own data tree.
     */
    match /users/{userId}/savedStays/{stayId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId);
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public read access to venue information.
     * @path /venues/{venueId}
     * @allow (get, list) - Public read access.
     * @deny (create, update, delete) - Writes are not allowed.
     * @principle Public read access for venues.
     */
    match /venues/{venueId} {
      allow get: if true;
      allow list: if true;

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public read access to experiences associated with a venue.
     * @path /venues/{venueId}/experiences/{experienceId}
     * @allow (get, list) - Public read access.
     * @deny (create, update, delete) - Writes are not allowed.
     * @principle Public read access for experiences.
     */
    match /venues/{venueId}/experiences/{experienceId} {
      allow get: if true;
      allow list: if true;

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Allows public read access to deals and enforces creator-only writes.
     * @path /deals/{dealId}
     * @allow (get, list) - Public read access.
     * @allow (create) - If the creatorId matches the user's ID.
     * @allow (update, delete) - If the user is the existing creator of the deal.
     * @deny (create) - If the creatorId does not match the user's ID.
     * @deny (update, delete) - If the user is not the creator of the deal.
     * @principle Public read, owner-only writes for deals.
     */
    match /deals/{dealId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.creatorId);
      allow delete: if isExistingOwner(resource.data.creatorId);
    }

    /**
     * @description Allows public read access to communities.
     * @path /communities/{communityId}
     * @allow (get, list) - Public read access.
     * @deny (create, update, delete) - Writes are not allowed.
     * @principle Public read access for communities.
     */
    match /communities/{communityId} {
      allow get: if true;
      allow list: if true;

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Manages access to social activities. Allows public read access and restricts writes to the host.
     * @path /socials/{socialId}
     * @allow (get, list) - Public read access.
     * @allow (create) - If the hostId matches the user's ID.
     * @allow (update, delete) - If the user is the existing host of the social activity.
     * @deny (create) - If the hostId does not match the user's ID.
     * @deny (update, delete) - If the user is not the host of the social activity.
     * @principle Public read, owner-only writes for social activities.
     */
    match /socials/{socialId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && request.resource.data.hostId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.hostId);
      allow delete: if isExistingOwner(resource.data.hostId);
    }

    /**
     * @description Manages participants in a social activity.
     * @path /socials/{socialId}/participants/{userId}
     * @allow (get, list) - Public read access.
     * @allow (create) - If the userId matches the authenticated user's ID (user can "ask to join").
     * @allow (update) - If the userId matches the authenticated user's ID (user can update their own status), OR if the user is the host.
     * @allow (delete) - If the userId matches the authenticated user's ID (user can leave), OR if the user is the host.
     * @deny (create) - If the userId does not match the authenticated user's ID.
     * @principle Allows users to manage their own participation and hosts to manage the group.
     */
    match /socials/{socialId}/participants/{userId} {
      allow get: if true;
      allow list: if true;
      
      allow create: if isOwner(userId); // I can "ask to join" as myself
      allow update: if isOwner(userId) || isHost(socialId); // I can update my *own* status, OR the *host* can update my status
      allow delete: if isOwner(userId) || isHost(socialId); // I can leave, OR the host can remove me
    }

    /**
     * @description Allows public read access to stays and enforces creator-only writes.
     * @path /stays/{stayId}
     * @allow (get, list) - Public read access.
     * @allow (create) - If the creatorId matches the user's ID.
     * @allow (update, delete) - If the user is the existing creator of the stay.
     * @deny (create) - If the creatorId does not match the user's ID.
     * @deny (update, delete) - If the user is not the creator of the stay.
     * @principle Public read, owner-only writes for stays.
     */
    match /stays/{stayId} {
      allow get: if true;
      allow list: if true;

      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.creatorId);
      allow delete: if isExistingOwner(resource.data.creatorId);
    }
  }
}