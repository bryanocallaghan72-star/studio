/**
 * @fileoverview Firestore Security Rules for iykyk Platform
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for user profiles,
 * public read access for venues and communities, and owner-only writes for
 * deals and experiences related to venues.  Role-based access is used for
 * community management. Data validation is minimal, focusing on authorization
 * and relational integrity for prototyping speed.
 *
 * Data Structure:
 * - /users/{userId}: User profile information, accessible only by the user.
 * - /venues/{venueId}: Venue information, publicly readable.
 * - /venues/{venueId}/experiences/{experienceId}: Experiences at a venue, writable only by the venue owner.
 * - /venues/{venueId}/deals/{dealId}: Deals at a venue, writable only by the deal creator.
 * - /communities/{communityId}: Community information, publicly readable, with role-based access control via a 'members' map.
 *
 * Key Security Decisions:
 * - Users can only read and write their own profile data.
 * - Venues and Communities are publicly readable.
 * - Experiences and Deals can only be created, updated, or deleted by the owning venue or creator, respectively.
 * - Communities use a `members` map for managing roles and permissions.
 * - Data validation is minimal to allow rapid iteration.
 *
 * Denormalization for Authorization:
 * - 'venueId' is denormalized into the 'experiences' and 'deals' subcollections to avoid 'get()' calls in security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Controls access to user profile information.
     * @path /users/{userId}
     * @allow (get) User with matching ID can read their profile.
     * @allow (create) User with matching ID can create their profile.
     * @allow (update) User with matching ID can update their profile.
     * @allow (delete) User with matching ID can delete their profile.
     * @deny (get) User trying to read another user's profile.
     * @deny (create) User trying to create a profile with an ID that doesn't match their own.
     * @deny (update) User trying to update another user's profile.
     * @deny (delete) User trying to delete another user's profile.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isSignedIn() {
        return request.auth != null;
      }

      function isOwner(userId) {
        return request.auth.uid == userId;
      }

      function isExistingOwner(userId) {
        return isOwner(userId) && exists(resource);
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to venue information.
     * @path /venues/{venueId}
     * @allow (get) Any user can read venue information.
     * @allow (list) Any user can list venues.
     * @deny (create) No user can create venues (assumed to be admin-only via backend).
     * @deny (update) No user can update venues (assumed to be admin-only via backend).
     * @deny (delete) No user can delete venues (assumed to be admin-only via backend).
     * @principle Allows public read access; restricts writes.
     */
    match /venues/{venueId} {
      allow get: if true;
      allow list: if true;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    /**
     * @description Controls access to experiences associated with a venue.
     * @path /venues/{venueId}/experiences/{experienceId}
     * @allow (get) Any user can read experience information.
     * @allow (list) Any user can list experiences for a venue.
     * @deny (create) Only the venue owner can create experiences.
     * @deny (update) Only the venue owner can update experiences.
     * @deny (delete) Only the venue owner can delete experiences.
     * @principle Enforces venue ownership for writes; allows public reads.
     */
    match /venues/{venueId}/experiences/{experienceId} {
      allow get: if true;
      allow list: if true;

      // CRITICAL: Cannot implement owner-only writes.  The 'Experience' entity is missing an 'ownerId' or 'authorId' field.
      allow create, update, delete: if request.auth.uid == resource.data.venueId; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to deals offered at a venue.
     * @path /venues/{venueId}/deals/{dealId}
     * @allow (get) Any user can read deal information.
     * @allow (list) Any user can list deals for a venue.
     * @deny (create) Only the deal creator can create deals.
     * @deny (update) Only the deal creator can update deals.
     * @deny (delete) Only the deal creator can delete deals.
     * @principle Enforces deal creator ownership for writes; allows public reads.
     */
    match /venues/{venueId}/deals/{dealId} {
      allow get: if true;
      allow list: if true;

      // CRITICAL: Cannot implement owner-only writes. The 'Deal' entity is missing an 'ownerId' or 'authorId' field.
      allow create, update, delete: if request.auth.uid == resource.data.venueId; // TODO: Add owner validation once the schema is updated with an ownership field.
    }

    /**
     * @description Controls access to community information.
     * @path /communities/{communityId}
     * @allow (get) Any user can read community information.
     * @allow (list) Any user can list communities.
     * @allow (create) Any authenticated user can create a community.
     * @deny (update) Only community members with 'admin' role can update a community.
     * @deny (delete) Only community members with 'admin' role can delete a community.
     * @principle Allows public read access; restricts writes to community admins.
     */
    match /communities/{communityId} {
       function isSignedIn() {
        return request.auth != null;
      }

      function isCommunityAdmin(communityId) {
        return get(/databases/$(database)/documents/communities/$(communityId)).data.members[request.auth.uid] == 'admin';
      }

      function isExistingCommunityAdmin(communityId) {
        return isCommunityAdmin(communityId);
      }
      allow get: if true;
      allow list: if true;
      allow create: if isSignedIn();
      allow update: if isExistingCommunityAdmin(communityId);
      allow delete: if isExistingCommunityAdmin(communityId);
    }
  }
}