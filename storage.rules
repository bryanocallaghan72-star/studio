rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // User Avatars: Public read, Authenticated write
    match /avatars/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User Banners: Public read, Authenticated write
    match /banners/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Feed Posts: Public read, Authenticated write
    match /posts/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Venue Images: Public read, Read-only (populated by scripts)
    match /venue_images/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
